# =============================================================================
# MSME Pathways Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# DJANGO SETTINGS
# =============================================================================

# Development: DEBUG=True | Production: DEBUG=False
DEBUG=True

# Generate a new secret key for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hosts
# Development: localhost,127.0.0.1
# Production: your-app.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# Pepper for password hashing (NEVER store this in the database)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_PEPPER=

# Field-level encryption key for sensitive database fields (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# =============================================================================
# DATABASE (MongoDB Atlas)
# =============================================================================

# Get from MongoDB Atlas: Database > Connect > Drivers > Python
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_NAME=capstone_db

# =============================================================================
# CORS (Frontend Origins)
# =============================================================================

# Comma-separated list of allowed frontend URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Required for CSRF validation on unsafe methods (POST/PUT/PATCH/DELETE)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Auth/session cookies (used for session hardening)
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_COOKIE_HTTPONLY=True
AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_PATH=/
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=False
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_SAMESITE=Lax

# IMPORTANT:
# - If frontend and backend are on different top-level domains (cross-site),
#   set AUTH_COOKIE_SAMESITE=None and CSRF_COOKIE_SAMESITE=None
# - SameSite=None requires AUTH_COOKIE_SECURE=True and CSRF_COOKIE_SECURE=True

# =============================================================================
# GROQ LLM (AI Chatbot)
# =============================================================================

# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_QUALIFICATION_MODEL=llama-3.1-8b-instant

# =============================================================================
# EMAIL (Gmail SMTP)
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Your Gmail address
EMAIL_HOST_USER=your-email@gmail.com

# App-specific password (not your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-16-character-app-password

# Sender name shown in emails
DEFAULT_FROM_EMAIL=MSME Pathways <your-email@gmail.com>

# Max time (seconds) for SMTP operations before failing fast
EMAIL_TIMEOUT=10

# =============================================================================
# DOCUMENT UPLOAD PERFORMANCE
# =============================================================================

# Run AI quality analysis during upload request
DOCUMENT_UPLOAD_AI_ANALYSIS=True

# Notify officers/admins for new pending documents
DOCUMENT_UPLOAD_NOTIFY_REVIEWERS=True

# Send reviewer notifications in a background thread (recommended)
DOCUMENT_UPLOAD_NOTIFY_ASYNC=True

# Document analysis validation thresholds
DOCUMENT_TYPE_CONFIDENCE_THRESHOLD=0.75
DOCUMENT_ENFORCE_TYPE_MATCH=True
DOCUMENT_REQUIRE_CNN_FOR_TYPE_VALIDATION=True

# =============================================================================
# CELERY (Background Tasks) - Optional
# =============================================================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# PRODUCTION SECURITY OVERRIDES (Optional; defaults are secure when DEBUG=False)
# =============================================================================

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
